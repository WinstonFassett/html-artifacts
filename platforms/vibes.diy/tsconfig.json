{
  "compilerOptions": {
    "target": "es2022",

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],

    "paths": {
      "~/vibes.diy/*": ["./vibes.diy/pkg/*"],
      "call-ai": ["./call-ai/pkg/index.ts"]
    },

    "resolveJsonModule": true,
    "jsx": "react",
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "outDir": "./dist",
    "removeComments": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "alwaysStrict": true,
    "skipLibCheck": true,
    "types": ["node", "deno"]
  },
  "include": [
    "call-ai/**/*",
    "img-vibes/**/*",
    "vibes-diy/**/*",
    "use-vibes/**/*",
    "vibes.diy/**/*",
    "prompts/**/*",
    "utils/**/*",
    "eval/**/*",
    "xhosting/**/*",
    "vibes.diy/api/svc/public/.ts"
  ],
  "exclude": [
    "vibes.diy/api/logpush-etl/**",
    "vibes.diy/tempo/**",
    "vibes.diy/**/slack/**",
    "vibes.diy/**/root.*",
    "vibes.diy/**/root.test.*",
    "vibes.diy/failback-homepage/**",
    "**/dist/**",
    "**/node_modules/**",
    "**/examples/**",
    "**/.react-router/**",
    "**/.netlify/**",
    "**/tests-new/**",
    "hosting/tests/unit/**",
    "use-vibes/tests/**"
  ]
}
