{
  "name": "vibes-diy",
  "version": "0.0.0",
  "type": "module",
  "main": "./index.js",
  "description": "Transform any DOM element into an AI-powered micro-app",
  "bin": {
    "vibes-diy": "cli/run.js"
  },
  "scripts": {
    "build": "core-cli tsc",
    "run": "node run.js",
    "test": "vitest run",
    "pack": "core-cli build -x '^' --doPack",
    "publish": "core-cli build -x '^'"
  },
  "keywords": [
    "ai",
    "dom",
    "micro-app",
    "generator",
    "web",
    "esm",
    "typescript"
  ],
  "contributors": [
    "J Chris Anderson",
    "Meno Abels"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@adviser/cement": "^0.5.34",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@fireproof/core": "0.24.19",
    "@fireproof/core-cli": "0.24.19",
    "@fireproof/core-device-id": "0.24.19",
    "@fireproof/core-keybag": "0.24.19",
    "@fireproof/core-protocols-dashboard": "0.24.19",
    "@fireproof/core-runtime": "0.24.19",
    "@fireproof/core-types-base": "0.24.19",
    "@fireproof/core-types-protocols-cloud": "0.24.19",
    "@fireproof/core-types-protocols-dashboard": "0.24.19",
    "@fireproof/use-fireproof": "0.24.19",
    "@vibes.diy/api-impl": "workspace:*",
    "@vibes.diy/api-types": "workspace:*",
    "@vibes.diy/call-ai-v2": "workspace:*",
    "@vibes.diy/prompts": "workspace:*",
    "arktype": "^2.2.0",
    "charwise": "^3.0.1",
    "cmd-ts": "^0.15.0",
    "tsx": "^4.22.3",
    "ws": "^8.19.0",
    "zod": "^3.25.67",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@vitest/browser-playwright": "~4.1.7",
    "vitest": "~4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VibesDIY/vibes.diy.git"
  }
