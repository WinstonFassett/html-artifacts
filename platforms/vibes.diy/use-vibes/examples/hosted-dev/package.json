{
  "name": "@vibes.diy/hosted-dev",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/ --config ../../../eslint.config.mjs",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm format && pnpm typecheck && pnpm lint && pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "serve -s dist"
  },
  "dependencies": {
    "call-ai": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "use-vibes": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/browser-playwright": "~4.1.7",
    "prettier": "^3.8.1",
    "serve": "^14.2.6",
    "typescript": "~6.0.3",
    "vite": "^7.3.3",
    "vitest": "~4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VibesDIY/vibes.diy.git"
  }
}
