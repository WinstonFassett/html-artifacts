---
interface Props { tags: string[]; sources: string[]; }
const { tags, sources } = Astro.props;

// Group 50 tags into semantic buckets
const TAG_GROUPS: { label: string; tags: string[] }[] = [
  {
    label: 'Type',
    tags: ['starter', 'template', 'tool', 'collection', 'prototype', 'demo'],
  },
  {
    label: 'Tech',
    tags: ['react', 'solid', 'gsap', 'wasm', 'web-components', 'webawesome', 'openrouter', 'matchina', 'chatscope', 'markstream'],
  },
  {
    label: 'Motion & Interactivity',
    tags: ['animation', 'motion', 'interactive', 'simulation', 'game', 'reactive', 'persistent', 'streaming'],
  },
  {
    label: 'Data & Viz',
    tags: ['chart', 'viz', 'data', 'diagram', 'map', 'dashboard', 'report'],
  },
  {
    label: 'Content',
    tags: ['article', 'blog', 'card', 'deck', 'document', 'editor', 'email', 'frame', 'magazine', 'markdown', 'poster', 'presentation', 'resume', 'social'],
  },
  {
    label: 'Media',
    tags: ['video', 'html-to-video', 'pdf', '3d', 'ai'],
  },
  {
    label: 'Apps',
    tags: ['app', 'chat'],
  },
];

// Any tag not in a group goes to Other
const allGroupedTags = new Set(TAG_GROUPS.flatMap(g => g.tags));
const otherTags = tags.filter(t => !allGroupedTags.has(t));
if (otherTags.length) TAG_GROUPS.push({ label: 'Other', tags: otherTags });

const views = [
  ['featured', 'Featured'],
  ['mine', 'Mine'],
  ['collected', 'Collected'],
  ['templates', 'Templates'],
  ['all', 'All'],
] as const;
---

<aside id="sidebar" class="w-60 shrink-0 border-r border-border flex flex-col sticky top-0 h-screen overflow-y-auto">
  <!-- Search -->
  <div class="px-4 pt-4 pb-3 border-b border-border">
    <input
      id="q"
      type="search"
      placeholder="Search…"
      class="w-full rounded border border-border bg-muted px-3 py-1.5 text-sm outline-none focus:border-accent placeholder:text-muted-foreground/60"
    />
  </div>

  <!-- Views -->
  <div class="px-4 pt-4 pb-2">
    <p class="mb-2 text-[0.65rem] font-semibold uppercase tracking-widest text-muted-foreground/50">View</p>
    <div class="flex flex-col gap-0.5">
      {views.map(([val, label]) => (
        <button
          class="view-btn w-full rounded px-2.5 py-1.5 text-left text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground data-[active]:bg-muted data-[active]:text-foreground data-[active]:font-medium"
          data-view={val}
          data-active={val === 'featured' ? '' : undefined}
        >{label}</button>
      ))}
    </div>
  </div>

  <div class="mx-4 border-t border-border my-2"></div>

  <!-- Source -->
  <div class="px-4 py-2">
    <p class="mb-2 text-[0.65rem] font-semibold uppercase tracking-widest text-muted-foreground/50">Source</p>
    <div class="flex flex-col gap-0.5">
      <button class="src-btn w-full rounded px-2.5 py-1.5 text-left text-sm text-muted-foreground hover:bg-muted hover:text-foreground data-[active]:bg-muted data-[active]:text-foreground data-[active]:font-medium" data-src="">all</button>
      {sources.map(s => (
        <button class="src-btn w-full rounded px-2.5 py-1.5 text-left text-sm text-muted-foreground hover:bg-muted hover:text-foreground data-[active]:bg-muted data-[active]:text-foreground data-[active]:font-medium" data-src={s}>{s}</button>
      ))}
    </div>
  </div>

  <div class="mx-4 border-t border-border my-2"></div>

  <!-- Tags by group -->
  <div class="px-4 py-2 pb-6 flex flex-col gap-3">
    <p class="text-[0.65rem] font-semibold uppercase tracking-widest text-muted-foreground/50">Tags</p>
    <button class="tag-btn w-full rounded px-2.5 py-1 text-left text-sm text-muted-foreground hover:bg-muted hover:text-foreground data-[active]:bg-muted data-[active]:text-foreground data-[active]:font-medium" data-tag="">all tags</button>

    {TAG_GROUPS.map(group => {
      const groupTags = group.tags.filter(t => tags.includes(t));
      if (!groupTags.length) return null;
      return (
        <details class="group/details" open>
          <summary class="flex cursor-pointer list-none items-center justify-between py-0.5 text-[0.7rem] font-semibold uppercase tracking-wider text-muted-foreground/70 hover:text-muted-foreground select-none">
            {group.label}
            <span class="chevron text-muted-foreground/40 transition-transform group-open/details:rotate-90">›</span>
          </summary>
          <div class="mt-1 flex flex-col gap-0.5 pl-1">
            {groupTags.map(t => (
              <button
                class="tag-btn w-full rounded px-2 py-1 text-left text-[0.8rem] text-muted-foreground hover:bg-muted hover:text-foreground data-[active]:bg-muted data-[active]:text-accent data-[active]:font-medium"
                data-tag={t}
              >{t}</button>
            ))}
          </div>
        </details>
      );
    })}
  </div>

  <!-- Count -->
  <div class="mt-auto px-4 py-3 border-t border-border sticky bottom-0 bg-background">
    <p id="count" class="text-xs text-muted-foreground"></p>
  </div>
</aside>

<script>
  const state = { view: 'featured', src: '', tag: '', q: '' };
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.card'));
  const countEl = document.getElementById('count')!;

  function inView(card: HTMLElement) {
    if (state.view === 'all') return true;
    if (state.view === 'featured') return card.dataset.featured === 'true';
    return card.dataset.bucket === state.view;
  }
  function apply() {
    let n = 0;
    for (const card of cards) {
      const cardTags = (card.dataset.tags || '').split(',');
      const show =
        inView(card) &&
        (!state.src || card.dataset.source === state.src) &&
        (!state.tag || cardTags.includes(state.tag)) &&
        (!state.q ||
          (card.dataset.name || '').includes(state.q) ||
          cardTags.some(t => t.includes(state.q)) ||
          (card.dataset.source || '').includes(state.q));
      card.classList.toggle('hidden', !show);
      if (show) n++;
    }
    countEl.textContent = `${n} artifact${n === 1 ? '' : 's'}`;
  }
  function setActive(selector: string, attr: string, val: string) {
    for (const b of document.querySelectorAll<HTMLElement>(selector)) {
      if (b.dataset[attr] === val) b.setAttribute('data-active', '');
      else b.removeAttribute('data-active');
    }
  }

  document.querySelectorAll<HTMLElement>('.view-btn').forEach(b =>
    b.addEventListener('click', () => {
      state.view = b.dataset.view!;
      setActive('.view-btn', 'view', state.view);
      apply();
    }));
  document.querySelectorAll<HTMLElement>('.src-btn').forEach(b =>
    b.addEventListener('click', () => {
      state.src = b.dataset.src!;
      setActive('.src-btn', 'src', state.src);
      apply();
    }));
  document.querySelectorAll<HTMLElement>('.tag-btn').forEach(b =>
    b.addEventListener('click', () => {
      state.tag = b.dataset.tag!;
      setActive('.tag-btn', 'tag', state.tag);
      apply();
    }));
  document.getElementById('q')!.addEventListener('input', e => {
    state.q = (e.target as HTMLInputElement).value.trim().toLowerCase();
    apply();
  });

  setActive('.src-btn', 'src', '');
  setActive('.tag-btn', 'tag', '');
  apply();
</script>
