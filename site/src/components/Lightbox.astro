---
// Click-to-run modal. The iframe src is the artifact's /artifacts/<path> URL,
// served verbatim from public/ so ESM imports resolve over HTTP.
---
<div id="lightbox" class="fixed inset-0 z-50 hidden flex-col bg-black/90 p-4 backdrop-blur-sm">
  <div class="mb-3 flex items-center justify-between gap-4">
    <h2 id="lb-title" class="truncate text-sm font-semibold text-white"></h2>
    <div class="flex items-center gap-3">
      <a id="lb-open" href="#" target="_blank" rel="noopener"
         class="rounded border border-white/20 px-2.5 py-1 text-xs text-white/80 hover:border-accent hover:text-accent">open ↗</a>
      <button id="lb-close" type="button"
              class="rounded border border-white/20 px-2.5 py-1 text-xs text-white/80 hover:border-accent hover:text-accent">close ✕</button>
    </div>
  </div>
  <iframe id="lb-frame" class="h-full w-full flex-1 rounded border border-white/10 bg-white"
          sandbox="allow-scripts allow-same-origin allow-forms"></iframe>
</div>

<script>
  const lb = document.getElementById('lightbox')!;
  const frame = document.getElementById('lb-frame') as HTMLIFrameElement;
  const title = document.getElementById('lb-title')!;
  const openLink = document.getElementById('lb-open') as HTMLAnchorElement;

  function open(run: string, name: string) {
    title.textContent = name;
    openLink.href = run;
    frame.src = run;
    lb.classList.remove('hidden');
    lb.classList.add('flex');
  }
  function close() {
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    frame.src = '';
  }

  document.addEventListener('click', (e) => {
    const trigger = (e.target as HTMLElement).closest('.preview-trigger');
    if (!trigger) return;
    const card = trigger.closest('.card') as HTMLElement | null;
    if (!card) return;
    open(card.dataset.run!, card.dataset.title || '');
  });
  document.getElementById('lb-close')!.addEventListener('click', close);
  lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
</script>
